# Clinic Ops Agent Enterprise - Production Environment
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ============================================
# APPLICATION CONFIGURATION
# ============================================
APP_NAME=Clinic Ops Agent Enterprise
APP_ENV=production
ENVIRONMENT=production
APP_VERSION=2.0.0
DEBUG=false

# ============================================
# API SECURITY
# ============================================
API_SECRET_KEY=your-super-secret-jwt-key-min-32-chars
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
API_ALGORITHM=HS256
JWT_ALGORITHM=HS256
API_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Rate Limiting (requests per hour by tier)
RATE_LIMIT_STARTER=1000
RATE_LIMIT_PROFESSIONAL=5000
RATE_LIMIT_ENTERPRISE=25000
RATE_LIMIT_UNLIMITED=100000

# ============================================
# DATABASE - MONGODB ATLAS
# ============================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/clinic_ops?retryWrites=true&w=majority
MONGODB_DB_NAME=clinic_ops_production
MONGODB_MAX_CONNECTIONS=50
MONGODB_MIN_CONNECTIONS=10

# ============================================
# CACHE - REDIS
# ============================================
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=your-redis-password
REDIS_SSL=true
REDIS_MAX_CONNECTIONS=100

# ============================================
# OBJECT STORAGE - MINIO/S3
# ============================================
S3_ENDPOINT=https://s3.amazonaws.com
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_BUCKET_NAME=clinic-ops-documents
S3_REGION=us-east-1
S3_SECURE=true

# MinIO Alternative (for on-premise)
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=clinic-ops
MINIO_SECURE=false

# ============================================
# AI/ML API KEYS
# ============================================

# Fireworks AI - Primary LLM for clinical analysis
FIREWORKS_API_KEY=fw_your_fireworks_api_key
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_TIMEOUT_SECONDS=60

# Mixedbread - RAG and embeddings
MIXEDBREAD_API_KEY=mb_your_mixedbread_api_key
MIXEDBREAD_TIMEOUT_SECONDS=30

# TinyFish Web Agent - Portal automation
TINYFISH_API_KEY=tf_your_tinyfish_api_key
TINYFISH_API_BASE_URL=https://agent.tinyfish.ai
TINYFISH_MODE=live
TINYFISH_TIMEOUT_SECONDS=300

# OpenAI - Fallback LLM (optional)
OPENAI_API_KEY=sk-your-openai-key

# ============================================
# OBSERVABILITY & MONITORING
# ============================================

# Axiom - Audit logging and observability
AXIOM_API_KEY=xa-your-axiom-token
AXIOM_DATASET=clinic-ops-production
AXIOM_ORG_ID=your-org-id

# AgentOps - Agent monitoring
AGENTOPS_API_KEY=ao-your-agentops-key
AGENTOPS_ENDPOINT=https://api.agentops.ai

# Prometheus - Metrics (optional self-hosted)
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ============================================
# COMPLIANCE & SECURITY
# ============================================

# HIPAA Compliance
HIPAA_ENCRYPTION_KEY=your-32-byte-encryption-key
HIPAA_BAA_ENABLED=true
HIPAA_AUDIT_RETENTION_DAYS=2555  # 7 years
HIPAA_LOG_LEVEL=INFO

# Encryption
FERNET_KEY=your-fernet-key-base64-encoded

# Session Security
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=strict
SESSION_TIMEOUT_MINUTES=60

# ============================================
# EHR INTEGRATION
# ============================================

# Epic FHIR
EPIC_CLIENT_ID=your-epic-client-id
EPIC_CLIENT_SECRET=your-epic-secret
EPIC_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth
EPIC_AUTH_URL=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/authorize
EPIC_TOKEN_URL=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/token

# Cerner
CERNER_CLIENT_ID=your-cerner-client-id
CERNER_CLIENT_SECRET=your-cerner-secret
CERNER_BASE_URL=https://fhir-ehr.cerner.com/r4/ec2458f0-1e22-11e6-b67b-9e71128cae77

# athenahealth
ATHENA_PRACTICE_ID=your-practice-id
ATHENA_CLIENT_ID=your-athena-client-id
ATHENA_CLIENT_SECRET=your-athena-secret
ATHENA_BASE_URL=https://api.platform.athenahealth.com

# ============================================
# EXTERNAL SERVICES
# ============================================

# 2Captcha - CAPTCHA solving service
TWOCAPTCHA_API_KEY=your-2captcha-key

# Webhook Secret for incoming webhooks
WEBHOOK_SECRET=your-webhook-signing-secret

# Email/SMTP (for notifications)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
SMTP_FROM=noreply@clinic-ops.ai
SMTP_TLS=true

# ============================================
# FEATURE FLAGS
# ============================================

# Enable/disable specific features
FEATURE_PRE_SUBMISSION_ENGINE=true
FEATURE_AI_NEGOTIATION=true
FEATURE_UNDERPAYMENT_RECOVERY=true
FEATURE_WHITE_LABEL=true
FEATURE_PHARMACY_DME=true
FEATURE_ADVANCED_STEALTH=true

# ============================================
# PERFORMANCE TUNING
# ============================================

# Worker Configuration
WORKERS=4
WORKER_TIMEOUT=120
KEEP_ALIVE=5
GRACEFUL_TIMEOUT=30

# Connection Pools
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Request Timeouts
REQUEST_TIMEOUT=60
CONNECT_TIMEOUT=10

# ============================================
# LOGGING
# ============================================

LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_OUTPUT=stdout

# Structured logging fields
LOG_INCLUDE_TIMESTAMP=true
LOG_INCLUDE_CORRELATION_ID=true
LOG_INCLUDE_REQUEST_ID=true

# ============================================
# HEALTH CHECKS
# ============================================

HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL_SECONDS=30
HEALTH_CHECK_TIMEOUT_SECONDS=5

# ============================================
# BACKUP & RECOVERY
# ============================================

BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
