# ============================================
# CLINIC OPS AGENT - PRODUCTION ENVIRONMENT
# ============================================
# ALL SERVICES ENABLED - NO MOCKS
# Fill in EVERY key to see the real product working
# ============================================

ENVIRONMENT=production
DEBUG=false

# ============================================
# TIER 1: CRITICAL - MUST HAVE THESE
# ============================================

# 1. FIREWORKS AI - Core AI Engine
# URL: https://fireworks.ai
# Cost: ~$20-50/month for demo usage
# Needed for: Denial prediction, appeal drafting, RAG
FIREWORKS_API_KEY=fw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. MONGODB ATLAS - Primary Database  
# URL: https://www.mongodb.com/cloud/atlas
# Cost: FREE M0 tier (512MB) or M10 $60/month
# Needed for: All data storage, audit logs, claims
MONGODB_ATLAS_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/clinic_ops_prod?retryWrites=true&w=majority

# 3. JWT SECRET - Authentication (32+ chars)
# Generate: openssl rand -base64 32
JWT_SECRET=YOUR_32_CHAR_SECRET_HERE_MINIMUM_LENGTH

# 4. TINYFISH - Anti-Bot Scraper
# URL: https://tinyfish.ai (apply for beta)
# Cost: Contact sales (usually $500+/month)
# Needed for: Payer portal automation, CAPTCHA bypass
TINYFISH_API_KEY=tf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TINYFISH_API_BASE_URL=https://agent.tinyfish.ai
TINYFISH_MODE=live

# 5. MIXEDBREAD - Embeddings for RAG
# URL: https://mixedbread.ai
# Cost: $0.001/1K tokens (~$5-10/month)
# Needed for: Vector search, claim similarity
MIXEDBREAD_API_KEY=mb_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# TIER 2: EHR INTEGRATIONS
# ============================================

# 6. EPIC FHIR - Largest EHR system
# URL: https://fhir.epic.com
# Cost: Free sandbox, production contact Epic
# Needed for: Patient data read/write
EPIC_CLIENT_ID=your-epic-client-id
EPIC_CLIENT_SECRET=your-epic-client-secret
EPIC_FHIR_URL=https://fhir.epic.com/interconnect-fhir-oauth

# 7. CERNER - Second largest EHR
# URL: https://code.cerner.com
# Cost: Developer free, production contact sales
CERNER_CLIENT_ID=your-cerner-client-id
CERNER_CLIENT_SECRET=your-cerner-client-secret
CERNER_TENANT_ID=your-cerner-tenant

# 8. ATHENAHEALTH - Cloud EHR
# URL: https://docs.athenahealth.com/api
# Cost: API access included with subscription
ATHENA_PRACTICE_ID=your-practice-id
ATHENA_CLIENT_ID=your-athena-client-id
ATHENA_CLIENT_SECRET=your-athena-secret

# ============================================
# TIER 3: CLEARINGHOUSES
# ============================================

# 9. WAYSTAR - Claims clearinghouse
# URL: https://waystar.com
# Cost: $0.25-0.50 per claim
# Needed for: Electronic claims submission
WAYSTAR_API_KEY=ws_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WAYSTAR_CLIENT_ID=your-waystar-client-id
WAYSTAR_CLIENT_SECRET=your-waystar-secret
WAYSTAR_BASE_URL=https://api.waystar.com

# 10. CHANGE HEALTHCARE - Largest clearinghouse
# URL: https://developers.changehealthcare.com
# Cost: Per transaction pricing
CHANGE_HEALTHCARE_CLIENT_ID=your-ch-client-id
CHANGE_HEALTHCARE_CLIENT_SECRET=your-ch-secret
CHANGE_HEALTHCARE_TOKEN_URL=https://api-sandbox.changehealthcare.com/apigateway

# ============================================
# TIER 4: MONITORING & OBSERVABILITY
# ============================================

# 11. AGENTOPS - Agent observability
# URL: https://agentops.ai
# Cost: Free tier (1K events), then $20/month
# Needed for: Agent tracing, debugging, analytics
AGENTOPS_API_KEY=ao_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 12. AXIOM - Structured logging
# URL: https://axiom.co
# Cost: Free tier (500GB), then usage-based
# Needed for: Centralized logs, HIPAA audit trails
AXIOM_API_KEY=xaat-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AXIOM_DATASET=clinic-ops-prod

# ============================================
# TIER 5: SECURITY & COMPLIANCE
# ============================================

# 13. FERNET KEY - Encryption (32 bytes base64)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=YOUR_FERNET_KEY_HERE_32_BYTES_BASE64=

# 14. API SECRET - Internal API auth
API_SECRET_KEY=your-api-secret-key-here-min-32-chars

# 15. HIPAA BAA ID
HIPAA_BAA_ENABLED=true
BAA_AGREEMENT_ID=baa_2025_001

# ============================================
# TIER 6: NOTIFICATIONS
# ============================================

# 16. TWILIO - SMS notifications
# URL: https://twilio.com
# Cost: ~$0.0075 per SMS
# Needed for: Patient alerts, approval requests
TWILIO_ACCOUNT_SID=AC_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# 17. SENDGRID - Email notifications
# URL: https://sendgrid.com
# Cost: Free tier (100 emails/day)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# INFRASTRUCTURE
# ============================================

# Redis (Upstash or local)
# Get free Redis: https://upstash.com
REDIS_URL=rediss://default:PASSWORD@YOUR-REDIS-URL.upstash.io:6379

# MinIO / S3
MINIO_ENDPOINT=https://s3.amazonaws.com
MINIO_ACCESS_KEY=your-aws-access-key
MINIO_SECRET_KEY=your-aws-secret-key
MINIO_BUCKET=clinic-ops-production

# ============================================
# ADVANCED FEATURES
# ============================================

# Google Cloud (for Vertex AI, Document AI)
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# OpenAI (fallback for certain tasks)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# RATE LIMITING & SECURITY
# ============================================

RATE_LIMIT_REQUESTS_PER_MINUTE=60
CORS_ALLOWED_ORIGINS=https://clinic-ops.ai,https://app.clinic-ops.ai
MAX_UPLOAD_SIZE_MB=50
SESSION_TIMEOUT_HOURS=24

# ============================================
# TOTAL ESTIMATED MONTHLY COST
# ============================================
# 
# Fireworks AI:        $20-50
# MongoDB Atlas M10:   $60
# TinyFish:            $500+ (contact sales)
# Mixedbread:          $5-10
# Twilio (1000 SMS):   $7.50
# SendGrid:            FREE
# Axiom:               FREE (500GB)
# AgentOps:            FREE (1K events)
# Redis (Upstash):     FREE (10K cmds/day)
# 
# TOTAL: ~$600-650/month for full production
# 
