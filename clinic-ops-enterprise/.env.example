# Clinic Ops Agent Enterprise - Environment Configuration

# App
ENVIRONMENT=development
DEBUG=false

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=clinic_ops_enterprise

# TinyFish API
TINYFISH_API_KEY=your_tinyfish_api_key_here
TINYFISH_API_BASE_URL=https://agent.tinyfish.ai
TINYFISH_MODE=live

# Payer Portal Workflow URLs (optional - will use defaults)
AETNA_WORKFLOW_URL=
UHC_WORKFLOW_URL=

# Fireworks.ai - LLM for denial analysis and appeal drafting
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Mixedbread - RAG for medical policy and clinical notes lookup
MIXEDBREAD_API_KEY=your_mixedbread_api_key_here

# Axiom - HIPAA audit logging
AXIOM_API_KEY=your_axiom_api_key_here
AXIOM_DATASET=clinic-ops-audit

# AgentOps - Agent monitoring and observability
AGENTOPS_API_KEY=your_agentops_api_key_here

# JWT - Authentication
JWT_SECRET=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# HIPAA Compliance
BAA_AGREEMENT_ID=baa_2025_001
DATA_RETENTION_YEARS=7

# Google Cloud - For cron jobs and Cloud Scheduler
GCP_PROJECT_ID=your_gcp_project_id
GCP_REGION=us-central1

# API Keys - Get from respective providers:
# TinyFish: https://tinyfish.ai
# Fireworks: https://fireworks.ai
# Mixedbread: https://mixedbread.ai
# Axiom: https://axiom.co
# AgentOps: https://agentops.ai
# MongoDB: https://mongodb.com/atlas
