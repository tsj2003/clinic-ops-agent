# ============================================
# CLINIC OPS AGENT - DEVELOPMENT ENVIRONMENT
# ============================================
# Copy this file to .env.local and fill in your API keys
# DO NOT COMMIT .env.local TO GIT
# ============================================

# ============================================
# REQUIRED - MUST FILL THESE IN
# ============================================

# 1. FIREWORKS AI API KEY
# Get from: https://fireworks.ai → Dashboard → API Keys
# Format: fw_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
FIREWORKS_API_KEY=fw_3a8fxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. MONGODB ATLAS CONNECTION STRING
# Get from: https://www.mongodb.com/cloud/atlas → Connect → Drivers → Python
# Replace <password> with your actual password
# Add /clinic_ops before ?retryWrites
MONGODB_ATLAS_URI=mongodb+srv://clinic_ops_user:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/clinic_ops?retryWrites=true&w=majority

# 3. JWT SECRET KEY (32+ characters)
# Generate with: openssl rand -base64 32
# Or use any random string (min 32 chars)
JWT_SECRET=clinic-ops-super-secret-jwt-key-2025-dev-only-secure-token

# ============================================
# OPTIONAL - CAN USE DEFAULTS/MOCK FOR NOW
# ============================================

# TinyFish Agent (optional - mock mode works for demo)
TINYFISH_API_KEY=mock-mode-for-development

# Mixedbread Embeddings (optional - local embeddings work)
MIXEDBREAD_API_KEY=mb_development_mock_key

# Waystar Clearinghouse (optional - mock for now)
WAYSTAR_CREDENTIALS=mock-waystar-credentials-dev

# ============================================
# DEVELOPMENT SETTINGS
# ============================================

# Environment mode
ENVIRONMENT=development
DEBUG=true

# Local MongoDB (fallback if Atlas not available)
MONGODB_URI=mongodb://localhost:27017/clinic_ops_dev

# Redis (local)
REDIS_URL=redis://localhost:6379/0

# MinIO (local S3-compatible)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=clinic-ops-dev

# ============================================
# FEATURE FLAGS (Development)
# ============================================

# Enable/disable features
HIPAA_BAA_ENABLED=true
AUDIT_LOGGING_ENABLED=true
AGENT_TRACING_ENABLED=true

# ============================================
# MONITORING & LOGGING
# ============================================

# Axiom (optional - for structured logging)
AXIOM_API_KEY=
AXIOM_DATASET=clinic-ops-dev

# AgentOps (optional - for agent observability)
AGENTOPS_API_KEY=

# ============================================
# SECURITY
# ============================================

# API Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Session timeout (hours)
JWT_EXPIRATION_HOURS=24

# Data retention
DATA_RETENTION_YEARS=7

# ============================================
# INSTRUCTIONS
# ============================================
# 
# 1. Copy this file:
#    cp .env.local.template .env.local
#
# 2. Edit .env.local and replace placeholder values
#
# 3. NEVER commit .env.local to git
#    (It's already in .gitignore)
#
# 4. Validate your config:
#    python scripts/validate_env.py
#
# 5. Start the API:
#    uvicorn api.main:app --reload
#
# 6. Open browser:
#    http://localhost:8000/docs (API docs)
#    frontend/dashboard.html (Dashboard)
#
# ============================================
